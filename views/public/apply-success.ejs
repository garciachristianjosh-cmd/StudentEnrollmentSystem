<%- include('../layouts/header') %>
<body class="bg-light">

<nav class="navbar navbar-dark" style="background:#1e2a3a;">
  <div class="container">
    <span class="navbar-brand fw-bold">
      <i class="bi bi-mortarboard-fill me-2 text-primary"></i>
      Student Enrollment System
    </span>
  </div>
</nav>

<div class="container py-5">
  <div class="row justify-content-center">
    <div class="col-12 col-md-6 text-center">
      <div class="card border-0 shadow-sm rounded-3 p-5">
        <i class="bi bi-check-circle-fill text-success mb-3"
           style="font-size:4rem;"></i>
        <h4 class="fw-bold mb-2">Application Submitted!</h4>
        <p class="text-muted mb-4">
          Your application has been received and is now
          <strong>pending review</strong>. The administrator
          will process your application and your login credentials
          will be provided upon approval.
        </p>
        <div class="d-flex justify-content-center gap-2 flex-wrap mt-2">
            <a href="/apply" class="btn btn-outline-primary">
              Submit Another Application
            </a>
            <a href="/auth/login" class="btn btn-primary">
              Login
            </a>
        </div>
      </div>
    </div>
  </div>
</div>

<%- include('../layouts/footer') %>