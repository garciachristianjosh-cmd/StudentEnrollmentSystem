<div class="d-flex align-items-center mb-4 gap-3">
  <a href="/admin/students" class="btn btn-sm btn-outline-secondary">
    <i class="bi bi-arrow-left"></i>
  </a>
  <div class="flex-grow-1">
    <h4 class="fw-bold mb-0" style="color:#1e2a3a;">
      <%= student.last_name %>, <%= student.first_name %>
      <% if (student.middle_name) { %>
        <%= student.middle_name.charAt(0) %>.
      <% } %>
    </h4>
    <% if (student.is_active) { %>
      <span class="badge bg-success-subtle text-success">Active</span>
    <% } else { %>
      <span class="badge bg-secondary-subtle text-secondary">Inactive</span>
    <% } %>
  </div>
  <a href="/admin/students/<%= student.id %>/edit"
     class="btn btn-outline-primary btn-sm">
    <i class="bi bi-pencil me-1"></i>Edit
  </a>
</div>

<div class="row g-4">
  <div class="col-lg-6">
    <div class="card border-0 shadow-sm rounded-3 h-100">
      <div class="card-header bg-white border-0 pt-4 pb-2 px-4">
        <h6 class="fw-bold mb-0">
          <i class="bi bi-person-fill me-2 text-primary"></i>
          Personal Information
        </h6>
      </div>
      <div class="card-body px-4">
        <table class="table table-borderless table-sm">
          <tr>
            <td class="text-muted fw-semibold" style="width:40%;">Student ID</td>
            <td>
              <span class="badge bg-light text-dark border fw-normal">
                <%= student.student_id %>
              </span>
            </td>
          </tr>
          <tr>
            <td class="text-muted fw-semibold">Full Name</td>
            <td>
              <%= student.first_name %>
              <%= student.middle_name || '' %>
              <%= student.last_name %>
            </td>
          </tr>
          <tr>
            <td class="text-muted fw-semibold">Email</td>
            <td><%= student.email %></td>
          </tr>
          <tr>
            <td class="text-muted fw-semibold">Contact</td>
            <td><%= student.contact_number || '—' %></td>
          </tr>
        </table>
      </div>
    </div>
  </div>

  <div class="col-lg-6">
    <div class="card border-0 shadow-sm rounded-3 h-100">
      <div class="card-header bg-white border-0 pt-4 pb-2 px-4">
        <h6 class="fw-bold mb-0">
          <i class="bi bi-mortarboard-fill me-2 text-success"></i>
          Academic Information
        </h6>
      </div>
      <div class="card-body px-4">
        <table class="table table-borderless table-sm">
          <tr>
            <td class="text-muted fw-semibold" style="width:40%;">Course</td>
            <td><%= student.course %></td>
          </tr>
          <tr>
            <td class="text-muted fw-semibold">Year Level</td>
            <td>Year <%= student.year_level %></td>
          </tr>
          <tr>
            <td class="text-muted fw-semibold">Username</td>
            <td><%= student.username %></td>
          </tr>
          <tr>
            <td class="text-muted fw-semibold">Password Status</td>
            <td>
              <% if (student.must_change_password) { %>
                <span class="badge bg-warning-subtle text-warning">
                  Must Change Password
                </span>
              <% } else { %>
                <span class="badge bg-success-subtle text-success">
                  Password Set
                </span>
              <% } %>
            </td>
          </tr>
        </table>
      </div>
    </div>
  </div>
</div>
