<!-- Page Header -->
<div class="d-flex align-items-center justify-content-between mb-4">
  <div>
    <h4 class="fw-bold mb-0" style="color:#1e2a3a;">Subject Management</h4>
    <p class="text-muted small mb-0"><%= total %> subject(s) found</p>
  </div>
  <a href="/admin/subjects/create" class="btn btn-primary">
    <i class="bi bi-plus-circle-fill me-2"></i>Add Subject
  </a>
</div>

<!-- Flash Messages -->
<% if (flash.success) { %>
  <div class="alert alert-success alert-dismissible fade show py-2" role="alert">
    <i class="bi bi-check-circle-fill me-2"></i><%= flash.success %>
    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
  </div>
<% } %>
<% if (flash.error) { %>
  <div class="alert alert-danger alert-dismissible fade show py-2" role="alert">
    <i class="bi bi-exclamation-triangle-fill me-2"></i><%= flash.error %>
    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
  </div>
<% } %>

<!-- Search -->
<div class="card border-0 shadow-sm rounded-3 mb-3">
  <div class="card-body py-3 px-4">
    <form method="GET" action="/admin/subjects" class="d-flex gap-2">
      <input
        type="text"
        name="search"
        class="form-control"
        placeholder="Search by code, name, instructor, or room..."
        value="<%= search %>"
      />
      <button class="btn btn-primary px-4" type="submit">
        <i class="bi bi-search"></i>
      </button>
      <% if (search) { %>
        <a href="/admin/subjects" class="btn btn-outline-secondary">Clear</a>
      <% } %>
    </form>
  </div>
</div>

<!-- Table -->
<div class="card border-0 shadow-sm rounded-3">
  <div class="table-responsive">
    <table class="table admin-table mb-0">
      <thead>
        <tr>
          <th class="px-4">Code</th>
          <th>Subject Name</th>
          <th class="text-center">Units</th>
          <th>Schedule</th>
          <th>Room</th>
          <th>Instructor</th>
          <th>Status</th>
          <th class="text-center">Actions</th>
        </tr>
      </thead>
      <tbody>
        <% if (subjects.length === 0) { %>
          <tr>
            <td colspan="8" class="text-center text-muted py-5">
              <i class="bi bi-book fs-2 d-block mb-2"></i>
              No subjects found.
            </td>
          </tr>
        <% } else { %>
          <% subjects.forEach(function(s) { %>
            <tr>
              <td class="px-4">
                <span class="badge bg-primary-subtle text-primary fw-semibold">
                  <%= s.subject_code %>
                </span>
              </td>
              <td class="fw-semibold"><%= s.subject_name %></td>
              <td class="text-center">
                <span class="badge bg-light text-dark border">
                  <%= s.units %> unit<%= s.units > 1 ? 's' : '' %>
                </span>
              </td>
              <td class="text-muted small"><%= s.schedule %></td>
              <td class="text-muted small"><%= s.room %></td>
              <td class="text-muted small"><%= s.instructor || '—' %></td>
              <td>
                <% if (s.is_active) { %>
                  <span class="badge rounded-pill bg-success-subtle text-success">
                    Active
                  </span>
                <% } else { %>
                  <span class="badge rounded-pill bg-secondary-subtle text-secondary">
                    Inactive
                  </span>
                <% } %>
              </td>
              <td class="text-center">
                <a href="/admin/subjects/<%= s.id %>/edit"
                   class="btn btn-sm btn-outline-secondary me-1"
                   title="Edit">
                  <i class="bi bi-pencil"></i>
                </a>

                <form method="POST"
                      action="/admin/subjects/<%= s.id %>/toggle"
                      class="d-inline">
                  <% if (s.is_active) { %>
                    <button type="submit"
                            class="btn btn-sm btn-outline-warning me-1"
                            title="Deactivate">
                      <i class="bi bi-pause-circle"></i>
                    </button>
                  <% } else { %>
                    <button type="submit"
                            class="btn btn-sm btn-outline-success me-1"
                            title="Activate">
                      <i class="bi bi-play-circle"></i>
                    </button>
                  <% } %>
                </form>

                <button type="button"
                        class="btn btn-sm btn-outline-danger"
                        title="Delete"
                        data-delete-id="<%= s.id %>"
                        data-delete-name="<%= s.subject_name %>"
                        data-delete-action="/admin/subjects/<%= s.id %>/delete"
                        data-delete-label="subject">
                  <i class="bi bi-trash"></i>
                </button>
              </td>
            </tr>
          <% }) %>
        <% } %>
      </tbody>
    </table>
  </div>

  <!-- Pagination -->
  <% if (totalPages > 1) { %>
    <div class="card-footer bg-white border-0 py-3 px-4">
      <div class="d-flex align-items-center justify-content-between">
        <span class="text-muted small">
          Page <%= page %> of <%= totalPages %>
        </span>
        <nav>
          <ul class="pagination pagination-sm mb-0">
            <li class="page-item <%= page <= 1 ? 'disabled' : '' %>">
              <a class="page-link"
                 href="/admin/subjects?page=<%= page - 1 %>&search=<%= search %>">
                &laquo;
              </a>
            </li>
            <% for (let p = 1; p <= totalPages; p++) { %>
              <li class="page-item <%= p === page ? 'active' : '' %>">
                <a class="page-link"
                   href="/admin/subjects?page=<%= p %>&search=<%= search %>">
                  <%= p %>
                </a>
              </li>
            <% } %>
            <li class="page-item <%= page >= totalPages ? 'disabled' : '' %>">
              <a class="page-link"
                 href="/admin/subjects?page=<%= page + 1 %>&search=<%= search %>">
                &raquo;
              </a>
            </li>
          </ul>
        </nav>
      </div>
    </div>
  <% } %>
</div>

<!-- Delete Confirmation Modal -->
<div class="modal fade" id="deleteModal" tabindex="-1">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content border-0 shadow">
      <div class="modal-header border-0 pb-0">
        <h5 class="modal-title fw-bold text-danger">
          <i class="bi bi-exclamation-triangle-fill me-2"></i>
          Delete <span id="deleteItemLabel">item</span>
        </h5>
        <button type="button" class="btn-close"
                data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <p class="mb-1">You are about to delete:</p>
        <p class="fw-bold fs-5 mb-1" id="deleteItemName"></p>
        <p class="text-muted small mb-0">
          This action cannot be undone.
        </p>
        <div class="alert alert-warning py-2 small mt-3 mb-0">
          <i class="bi bi-exclamation-triangle-fill me-1"></i>
          If students are enrolled in this subject, deletion will
          be blocked. Use <strong>Deactivate</strong> instead.
        </div>
      </div>
      <div class="modal-footer border-0 pt-0">
        <button type="button" class="btn btn-secondary"
                data-bs-dismiss="modal">Cancel</button>
        <form id="deleteForm" method="POST">
          <button type="submit" class="btn btn-danger">
            <i class="bi bi-trash me-1"></i>Delete
          </button>
        </form>
      </div>
    </div>
  </div>
</div>