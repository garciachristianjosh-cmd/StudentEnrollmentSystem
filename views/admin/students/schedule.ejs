<!-- Page Header -->
<div class="mb-4">
  <h4 class="fw-bold mb-0" style="color:#1e2a3a;">Class Schedule</h4>
  <p class="text-muted small mb-0">
    <%= student.first_name %> <%= student.last_name %> &nbsp;|&nbsp;
    <%= student.course %> &nbsp;|&nbsp; Year <%= student.year_level %>
  </p>
</div>

<% if (enrolled.length === 0) { %>
  <div class="card border-0 shadow-sm rounded-3">
    <div class="card-body text-center text-muted py-5">
      <i class="bi bi-calendar-x fs-2 d-block mb-2"></i>
      No class schedule yet.
      <div class="small mt-1">Please contact your administrator.</div>
    </div>
  </div>
<% } else { %>

  <!-- Print Button -->
  <div class="d-flex justify-content-end mb-3">
    <button class="btn btn-outline-secondary btn-sm" onclick="window.print()">
      <i class="bi bi-printer me-1"></i>Print Schedule
    </button>
  </div>

  <!-- Schedule Cards -->
  <div class="row g-3" id="printable">
    <% enrolled.forEach(function(e, index) { %>
      <%
        // Cycle through accent colors for visual variety
        const colors = [
          '#3b82f6','#10b981','#f59e0b',
          '#8b5cf6','#ef4444','#06b6d4'
        ];
        const color = colors[index % colors.length];
      %>
      <div class="col-md-6 col-lg-4">
        <div class="card schedule-card h-100"
             style="border-left-color:<%= color %>;">
          <div class="card-body p-4">

            <div class="subject-code mb-1" style="color:<%= color %>;">
              <%= e.subject_code %>
            </div>

            <h6 class="fw-bold mb-3" style="color:#1e2a3a;">
              <%= e.subject_name %>
            </h6>

            <div class="d-flex flex-column gap-2">
              <div class="d-flex align-items-start gap-2 small text-muted">
                <i class="bi bi-clock mt-1 flex-shrink-0"
                   style="color:<%= color %>;"></i>
                <span><%= e.schedule %></span>
              </div>
              <div class="d-flex align-items-start gap-2 small text-muted">
                <i class="bi bi-geo-alt mt-1 flex-shrink-0"
                   style="color:<%= color %>;"></i>
                <span><%= e.room %></span>
              </div>
              <% if (e.instructor) { %>
                <div class="d-flex align-items-start gap-2 small text-muted">
                  <i class="bi bi-person mt-1 flex-shrink-0"
                     style="color:<%= color %>;"></i>
                  <span><%= e.instructor %></span>
                </div>
              <% } %>
              <div class="d-flex align-items-center gap-2 small mt-1">
                <span class="badge rounded-pill"
                      style="background:<%=color%>20;color:<%=color%>;">
                  <%= e.units %> unit<%= e.units !== 1 ? 's' : '' %>
                </span>
              </div>
            </div>

          </div>
        </div>
      </div>
    <% }) %>
  </div>

  <!-- Print styles -->
  <style>
    @media print {
      #student-nav,
      .btn { display: none !important; }
      .schedule-card { break-inside: avoid; }
      body { background: #fff !important; }
    }
  </style>

<% } %>