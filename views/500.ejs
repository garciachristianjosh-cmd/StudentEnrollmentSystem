<%- include('layouts/header') %>

<div class="container-fluid min-vh-100 d-flex align-items-center
            justify-content-center bg-light">
  <div class="col-12 col-md-6 text-center">
    <h1 class="display-1 fw-bold text-warning">500</h1>
    <p class="fs-4">Internal Server Error.</p>
    <p class="text-muted">Something went wrong on our end.</p>

    <% if (typeof error !== 'undefined' && error) { %>
      <pre class="text-start bg-dark text-light p-3 rounded small
                  mt-4 overflow-auto" style="max-height:300px;">
<%= error.stack %>
      </pre>
    <% } %>

    <a href="/" class="btn btn-primary mt-3">Go Home</a>
  </div>
</div>

<%- include('layouts/footer') %>