<!-- Page Header -->
<div class="d-flex align-items-center mb-4 gap-3">
  <a href="/admin/enrollment" class="btn btn-sm btn-outline-secondary">
    <i class="bi bi-arrow-left"></i>
  </a>
  <div>
    <h4 class="fw-bold mb-0" style="color:#1e2a3a;">
      <%= student.last_name %>, <%= student.first_name %>
    </h4>
    <p class="text-muted small mb-0">
      <%= student.student_id %> &nbsp;|&nbsp;
      <%= student.course %> &nbsp;|&nbsp;
      Year <%= student.year_level %>
    </p>
  </div>
</div>

<!-- Flash Messages -->
<% if (flash.success) { %>
  <div class="alert alert-success alert-dismissible fade show py-2" role="alert">
    <i class="bi bi-check-circle-fill me-2"></i><%= flash.success %>
    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
  </div>
<% } %>
<% if (flash.error) { %>
  <div class="alert alert-danger alert-dismissible fade show" role="alert">
    <div class="fw-semibold mb-1">
      <i class="bi bi-exclamation-triangle-fill me-2"></i>
      Enrollment could not be completed:
    </div>
    <ul class="mb-0 ps-3 small">
      <% flash.error.split(' | ').forEach(function(msg) { %>
        <li><%= msg %></li>
      <% }) %>
    </ul>
    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
  </div>
<% } %>

<!-- Units Summary Bar -->
<%
  const unitPercent  = Math.min(Math.round((currentUnits / maxUnits) * 100), 100);
  const unitsLeft    = maxUnits - currentUnits;
  let   barColor     = 'bg-success';
  if (unitPercent >= 90) barColor = 'bg-danger';
  else if (unitPercent >= 70) barColor = 'bg-warning';
%>
<div class="card border-0 shadow-sm rounded-3 mb-4">
  <div class="card-body py-3 px-4">
    <div class="d-flex align-items-center justify-content-between mb-2">
      <span class="fw-semibold small">Unit Load</span>
      <span class="small text-muted">
        <strong class="text-dark"><%= currentUnits %></strong>
        / <%= maxUnits %> units
        <% if (unitsLeft > 0) { %>
          &nbsp;·&nbsp;
          <span class="text-success fw-semibold">
            <%= unitsLeft %> unit<%= unitsLeft !== 1 ? 's' : '' %> remaining
          </span>
        <% } else { %>
          &nbsp;·&nbsp;
          <span class="text-danger fw-semibold">Maximum reached</span>
        <% } %>
      </span>
    </div>
    <div class="progress" style="height:8px;">
      <div class="progress-bar <%= barColor %>"
           id="unitProgressBar"
           data-width="<%= unitPercent %>"
           role="progressbar"
           aria-valuenow="<%= currentUnits %>"
           aria-valuemin="0"
           aria-valuemax="<%= maxUnits %>">
      </div>
    </div>
  </div>
</div>

<div class="row g-4">

  <!-- Left: Currently Enrolled -->
  <div class="col-lg-6">
    <div class="card border-0 shadow-sm rounded-3 h-100">
      <div class="card-header bg-white border-0 pt-4 pb-2 px-4">
        <div class="d-flex align-items-center justify-content-between">
          <h6 class="fw-bold mb-0">
            <i class="bi bi-check2-circle me-2 text-success"></i>
            Enrolled Subjects
          </h6>
          <span class="badge bg-success-subtle text-success">
            <%= enrolled.length %> subject<%= enrolled.length !== 1 ? 's' : '' %>
          </span>
        </div>
      </div>
      <div class="card-body p-0">
        <% if (enrolled.length === 0) { %>
          <div class="text-center text-muted py-5 px-4">
            <i class="bi bi-inbox fs-2 d-block mb-2"></i>
            No subjects enrolled yet.
          </div>
        <% } else { %>
          <div class="table-responsive">
            <table class="table admin-table mb-0">
              <thead>
                <tr>
                  <th class="px-4">Code</th>
                  <th>Subject</th>
                  <th class="text-center">Units</th>
                  <th class="text-center">Remove</th>
                </tr>
              </thead>
              <tbody>
                <% enrolled.forEach(function(e) { %>
                  <tr>
                    <td class="px-4">
                      <span class="badge bg-primary-subtle text-primary fw-semibold">
                        <%= e.subject_code %>
                      </span>
                    </td>
                    <td>
                      <div class="fw-semibold small"><%= e.subject_name %></div>
                      <div class="text-muted" style="font-size:0.75rem;">
                        <%= e.schedule %> | <%= e.room %>
                      </div>
                    </td>
                    <td class="text-center">
                      <span class="badge bg-light text-dark border">
                        <%= e.units %>
                      </span>
                    </td>
                    <td class="text-center">
                      <form method="POST"
                            action="/admin/enrollment/<%= student.id %>/remove/<%= e.enrollment_id %>">
                        <button type="submit"
                                class="btn btn-sm btn-outline-danger"
                                title="Remove"
                                onclick="return confirm('Remove this subject from enrollment?')">
                          <i class="bi bi-x-lg"></i>
                        </button>
                      </form>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>

          <%
            const totalUnits = enrolled.reduce(function(sum, e) {
              return sum + e.units;
            }, 0);
          %>
          <div class="px-4 py-3 border-top bg-light d-flex justify-content-between align-items-center">
            <span class="fw-semibold small">Total Units:</span>
            <span class="badge bg-primary"><%= totalUnits %></span>
          </div>
        <% } %>
      </div>
    </div>
  </div>

  <!-- Right: Available Subjects -->
  <div class="col-lg-6">
    <div class="card border-0 shadow-sm rounded-3 h-100">
      <div class="card-header bg-white border-0 pt-4 pb-2 px-4">
        <div class="d-flex align-items-center justify-content-between">
          <h6 class="fw-bold mb-0">
            <i class="bi bi-plus-circle me-2 text-primary"></i>
            Available Subjects
          </h6>
          <span class="badge bg-primary-subtle text-primary">
            <%= available.length %> available
          </span>
        </div>
      </div>

      <% if (currentUnits >= maxUnits) { %>
        <div class="card-body text-center text-muted py-5">
          <i class="bi bi-slash-circle fs-2 d-block mb-2 text-danger"></i>
          <span class="fw-semibold text-danger">Maximum unit load reached.</span>
          <div class="small mt-1">
            Remove a subject before adding new ones.
          </div>
        </div>
      <% } else if (available.length === 0) { %>
        <div class="card-body text-center text-muted py-5">
          <i class="bi bi-check-all fs-2 d-block mb-2 text-success"></i>
          All active subjects are already enrolled.
        </div>
      <% } else { %>
        <form method="POST" action="/admin/enrollment/<%= student.id %>">
          <div class="card-body p-0">
            <div class="table-responsive">
              <table class="table admin-table mb-0">
                <thead>
                  <tr>
                    <th class="px-4" style="width:40px;">
                      <input type="checkbox" id="selectAll"
                             class="form-check-input" />
                    </th>
                    <th>Code</th>
                    <th>Subject</th>
                    <th class="text-center">Units</th>
                  </tr>
                </thead>
                <tbody>
                  <% available.forEach(function(sub) { %>
                    <tr>
                      <td class="px-4">
                        <input type="checkbox"
                               class="form-check-input subject-checkbox"
                               name="subject_ids"
                               value="<%= sub.id %>"
                               data-units="<%= sub.units %>" />
                      </td>
                      <td>
                        <span class="badge bg-primary-subtle text-primary fw-semibold">
                          <%= sub.subject_code %>
                        </span>
                      </td>
                      <td>
                        <div class="fw-semibold small"><%= sub.subject_name %></div>
                        <div class="text-muted" style="font-size:0.75rem;">
                          <%= sub.schedule %> | <%= sub.room %>
                        </div>
                      </td>
                      <td class="text-center">
                        <span class="badge bg-light text-dark border">
                          <%= sub.units %>
                        </span>
                      </td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
          </div>

          <div class="card-footer bg-white border-0 px-4 py-3">
            <div class="d-flex align-items-center justify-content-between">
              <div class="small text-muted">
                <span id="selectedCount">0 selected</span>
                &nbsp;·&nbsp;
                <span id="selectedUnits">0 units</span>
                &nbsp;·&nbsp;
                After: <span id="projectedUnits"><%= currentUnits %></span>
                / <%= maxUnits %>
              </div>
              <button type="submit" class="btn btn-primary px-4"
                      id="enrollBtn" disabled>
                <i class="bi bi-plus-circle-fill me-2"></i>Enroll Selected
              </button>
            </div>
          </div>
        </form>
      <% } %>
    </div>
  </div>

</div>

<!-- Pass server values to JS via data attributes -->
<div id="enrollmentMeta"
     data-current-units="<%= currentUnits %>"
     data-max-units="<%= maxUnits %>"
     style="display:none;">
</div>

<script>
  const meta         = document.getElementById('enrollmentMeta');
  const progressBar = document.getElementById('unitProgressBar');
    if (progressBar) {
      progressBar.style.width = progressBar.getAttribute('data-width') + '%';
  }
  const currentUnits = parseInt(meta.getAttribute('data-current-units')) || 0;
  const maxUnits     = parseInt(meta.getAttribute('data-max-units'))     || 25;

  const checkboxes     = document.querySelectorAll('.subject-checkbox');
  const selectAll      = document.getElementById('selectAll');
  const enrollBtn      = document.getElementById('enrollBtn');
  const selectedCount  = document.getElementById('selectedCount');
  const selectedUnits  = document.getElementById('selectedUnits');
  const projectedUnits = document.getElementById('projectedUnits');

  function updateState() {
    const checked     = Array.from(checkboxes).filter(cb => cb.checked);
    const count       = checked.length;
    const units       = checked.reduce((sum, cb) =>
      sum + parseInt(cb.getAttribute('data-units') || 0), 0
    );
    const projected   = currentUnits + units;
    const wouldExceed = projected > maxUnits;

    if (selectedCount)  selectedCount.textContent  = count + ' selected';
    if (selectedUnits)  selectedUnits.textContent  = units + ' unit' + (units !== 1 ? 's' : '');
    if (projectedUnits) projectedUnits.textContent = projected;

    if (projectedUnits) {
      projectedUnits.className = wouldExceed ? 'text-danger fw-bold' : '';
    }

    if (enrollBtn) {
      enrollBtn.disabled  = count === 0 || wouldExceed;
      enrollBtn.className = wouldExceed
        ? 'btn btn-danger px-4'
        : 'btn btn-primary px-4';
    }

    if (selectAll) {
      selectAll.indeterminate = count > 0 && count < checkboxes.length;
      selectAll.checked       = count === checkboxes.length && checkboxes.length > 0;
    }
  }

  checkboxes.forEach(cb => cb.addEventListener('change', updateState));

  if (selectAll) {
    selectAll.addEventListener('change', function () {
      checkboxes.forEach(cb => { cb.checked = selectAll.checked; });
      updateState();
    });
  }
</script>