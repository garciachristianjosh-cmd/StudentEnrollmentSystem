<!-- Profile Card -->
<div class="profile-card mb-4">
  <div class="d-flex align-items-center gap-3 mb-3">
    <div class="profile-avatar">
      <%= student.first_name.charAt(0).toUpperCase() %>
    </div>
    <div>
      <h4 class="fw-bold mb-0">
        <%= student.first_name %>
        <%= student.middle_name ? student.middle_name + ' ' : '' %>
        <%= student.last_name %>
      </h4>
      <div class="opacity-75 small"><%= student.email %></div>
    </div>
  </div>

  <div class="d-flex flex-wrap gap-2">
    <span class="profile-pill">
      <i class="bi bi-person-badge"></i>
      <%= student.student_id %>
    </span>
    <span class="profile-pill">
      <i class="bi bi-mortarboard"></i>
      <%= student.course %>
    </span>
    <span class="profile-pill">
      <i class="bi bi-calendar3"></i>
      Year <%= student.year_level %>
    </span>
    <span class="profile-pill">
      <i class="bi bi-book"></i>
      <%= totalUnits %> unit<%= totalUnits !== 1 ? 's' : '' %> enrolled
    </span>
  </div>
</div>

<!-- Summary Cards -->
<div class="row g-3 mb-4">
  <div class="col-sm-4">
    <div class="card border-0 shadow-sm rounded-3 text-center p-3">
      <div class="display-6 fw-bold text-primary"><%= enrolled.length %></div>
      <div class="text-muted small mt-1">Enrolled Subjects</div>
    </div>
  </div>
  <div class="col-sm-4">
    <div class="card border-0 shadow-sm rounded-3 text-center p-3">
      <div class="display-6 fw-bold text-success"><%= totalUnits %></div>
      <div class="text-muted small mt-1">Total Units</div>
    </div>
  </div>
  <div class="col-sm-4">
    <div class="card border-0 shadow-sm rounded-3 text-center p-3">
      <div class="display-6 fw-bold text-warning"><%= student.year_level %></div>
      <div class="text-muted small mt-1">Year Level</div>
    </div>
  </div>
</div>

<!-- Recent Enrollments Preview -->
<div class="card border-0 shadow-sm rounded-3">
  <div class="card-header bg-white border-0 pt-4 pb-2 px-4
              d-flex align-items-center justify-content-between">
    <h6 class="fw-bold mb-0">
      <i class="bi bi-list-check me-2 text-primary"></i>
      My Enrolled Subjects
    </h6>
    <a href="/student/subjects" class="btn btn-sm btn-outline-primary">
      View All
    </a>
  </div>

  <% if (enrolled.length === 0) { %>
    <div class="card-body text-center text-muted py-5">
      <i class="bi bi-inbox fs-2 d-block mb-2"></i>
      You are not enrolled in any subjects yet.
      <div class="small mt-1">
        Please contact your administrator.
      </div>
    </div>
  <% } else { %>
    <div class="card-body p-0">
      <div class="table-responsive">
        <table class="table student-table mb-0">
          <thead>
            <tr>
              <th class="px-4">Code</th>
              <th>Subject</th>
              <th>Units</th>
              <th>Schedule</th>
              <th>Room</th>
            </tr>
          </thead>
          <tbody>
            <% enrolled.slice(0, 5).forEach(function(e) { %>
              <tr>
                <td class="px-4">
                  <span class="badge bg-primary-subtle text-primary fw-semibold">
                    <%= e.subject_code %>
                  </span>
                </td>
                <td class="fw-semibold"><%= e.subject_name %></td>
                <td>
                  <span class="badge bg-light text-dark border">
                    <%= e.units %>
                  </span>
                </td>
                <td class="text-muted small"><%= e.schedule %></td>
                <td class="text-muted small"><%= e.room %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  <% } %>
</div>