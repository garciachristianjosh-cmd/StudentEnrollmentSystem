<!-- Page Header -->
<div class="d-flex align-items-center justify-content-between mb-4">
  <div>
    <h4 class="fw-bold mb-0" style="color:#1e2a3a;">Class Schedule</h4>
    <p class="text-muted small mb-0">
      <%= student.first_name %> <%= student.last_name %>
      &nbsp;|&nbsp; <%= student.course %>
      &nbsp;|&nbsp; Year <%= student.year_level %>
    </p>
  </div>
  <button class="btn btn-outline-secondary btn-sm no-print"
          id="printScheduleBtn">
    <i class="bi bi-printer me-1"></i>Print Schedule
  </button>
</div>

<% if (enrolled.length === 0) { %>
  <div class="card border-0 shadow-sm rounded-3">
    <div class="card-body text-center text-muted py-5">
      <i class="bi bi-calendar-x fs-2 d-block mb-2"></i>
      No class schedule yet.
      <div class="small mt-1">Please contact your administrator.</div>
    </div>
  </div>
<% } else { %>

  <%
    const scheduleColors = [
      '#3b82f6','#10b981','#f59e0b',
      '#8b5cf6','#ef4444','#06b6d4',
      '#ec4899','#14b8a6'
    ];
  %>

  <!-- Schedule Cards -->
  <div class="row g-3">
    <% enrolled.forEach(function(e, index) { %>
      <% const cardColor = scheduleColors[index % scheduleColors.length]; %>
      <div class="col-md-6 col-lg-4">
        <div class="card schedule-card h-100"
             data-color="<%= cardColor %>">
          <div class="card-body p-4">

            <div class="subject-code mb-1 card-accent-text">
              <%= e.subject_code %>
            </div>

            <h6 class="fw-bold mb-3" style="color:#1e2a3a;">
              <%= e.subject_name %>
            </h6>

            <div class="d-flex flex-column gap-2">

              <div class="d-flex align-items-start gap-2 small">
                <i class="bi bi-clock mt-1 flex-shrink-0 card-accent-icon"></i>
                <span class="text-muted"><%= e.schedule %></span>
              </div>

              <div class="d-flex align-items-start gap-2 small">
                <i class="bi bi-geo-alt mt-1 flex-shrink-0 card-accent-icon"></i>
                <span class="text-muted"><%= e.room %></span>
              </div>

              <% if (e.instructor) { %>
                <div class="d-flex align-items-start gap-2 small">
                  <i class="bi bi-person mt-1 flex-shrink-0 card-accent-icon"></i>
                  <span class="text-muted"><%= e.instructor %></span>
                </div>
              <% } %>

              <div class="mt-2">
                <span class="badge rounded-pill fw-normal card-accent-badge">
                  <%= e.units %> unit<%= e.units !== 1 ? 's' : '' %>
                </span>
              </div>

            </div>
          </div>
        </div>
      </div>
    <% }) %>
  </div>

  <!-- Units Summary -->
  <%
    const totalUnitsSchedule = enrolled.reduce(function(sum, e) {
      return sum + e.units;
    }, 0);
  %>
  <div class="card border-0 shadow-sm rounded-3 mt-4 no-print">
    <div class="card-body py-3 px-4
                d-flex justify-content-between align-items-center">
      <span class="fw-semibold small text-muted">
        Total:
        <%= enrolled.length %> subject<%= enrolled.length !== 1 ? 's' : '' %>
      </span>
      <span class="fw-semibold small">
        Total Units:
        <span class="badge bg-primary ms-1">
          <%= totalUnitsSchedule %>
        </span>
      </span>
    </div>
  </div>

<% } %>

<script>
  // Apply accent colors from data attributes — keeps EJS out of style=""
  document.querySelectorAll('.schedule-card[data-color]').forEach(function(card) {
    const color = card.getAttribute('data-color');
    if (!color) return;

    // Border left
    card.style.borderLeftColor = color;

    // Subject code text
    const codeEl = card.querySelector('.card-accent-text');
    if (codeEl) codeEl.style.color = color;

    // Icons
    card.querySelectorAll('.card-accent-icon').forEach(function(icon) {
      icon.style.color = color;
    });

    // Badge — light background version of the color
    const badge = card.querySelector('.card-accent-badge');
    if (badge) {
      badge.style.backgroundColor = color + '22';
      badge.style.color           = color;
    }
  });
</script>