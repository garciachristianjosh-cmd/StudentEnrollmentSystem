<!-- Page Header -->
<div class="mb-4">
  <h4 class="fw-bold mb-0" style="color:#1e2a3a;">My Subjects</h4>
  <p class="text-muted small mb-0">
    <%= enrolled.length %> subject<%= enrolled.length !== 1 ? 's' : '' %> —
    <%= totalUnits %> total unit<%= totalUnits !== 1 ? 's' : '' %>
  </p>
</div>

<% if (enrolled.length === 0) { %>
  <div class="card border-0 shadow-sm rounded-3">
    <div class="card-body text-center text-muted py-5">
      <i class="bi bi-inbox fs-2 d-block mb-2"></i>
      You are not enrolled in any subjects yet.
      <div class="small mt-1">Please contact your administrator.</div>
    </div>
  </div>
<% } else { %>
  <div class="card border-0 shadow-sm rounded-3">
    <div class="table-responsive">
      <table class="table student-table mb-0">
        <thead>
          <tr>
            <th class="px-4">#</th>
            <th>Code</th>
            <th>Subject Name</th>
            <th class="text-center">Units</th>
            <th>Schedule</th>
            <th>Room</th>
            <th>Instructor</th>
          </tr>
        </thead>
        <tbody>
          <% enrolled.forEach(function(e, index) { %>
            <tr>
              <td class="px-4 text-muted"><%= index + 1 %></td>
              <td>
                <span class="badge bg-primary-subtle text-primary fw-semibold">
                  <%= e.subject_code %>
                </span>
              </td>
              <td class="fw-semibold"><%= e.subject_name %></td>
              <td class="text-center">
                <span class="badge bg-light text-dark border">
                  <%= e.units %>
                </span>
              </td>
              <td class="text-muted small"><%= e.schedule %></td>
              <td class="text-muted small"><%= e.room %></td>
              <td class="text-muted small"><%= e.instructor || '—' %></td>
            </tr>
          <% }) %>
        </tbody>
        <tfoot class="table-light">
          <tr>
            <td colspan="3" class="px-4 fw-bold text-end">Total Units:</td>
            <td class="text-center">
              <span class="badge bg-primary"><%= totalUnits %></span>
            </td>
            <td colspan="3"></td>
          </tr>
        </tfoot>
      </table>
    </div>
  </div>
<% } %>