<%- include('../layouts/header') %>

<div class="container-fluid min-vh-100 d-flex align-items-center
            justify-content-center bg-light">
  <div class="col-12 col-sm-8 col-md-5 col-lg-4">

    <div class="card shadow-sm border-0 rounded-3">
      <div class="card-body p-4 p-md-5">

        <div class="text-center mb-4">
          <i class="bi bi-shield-lock-fill text-primary"
             style="font-size:3rem;"></i>
          <h4 class="fw-bold mt-2 mb-0">Reset Password</h4>
          <p class="text-muted small mt-1">
            Enter your new password below.
          </p>
        </div>

        <% if (error) { %>
          <div class="alert alert-danger py-2 small" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-1"></i>
            <%= error %>
          </div>
        <% } %>

        <% if (success) { %>
          <div class="alert alert-success py-2 small" role="alert">
            <i class="bi bi-check-circle-fill me-1"></i>
            <%= success %>
          </div>
          <div class="d-grid mt-3">
            <a href="/auth/login" class="btn btn-primary">
              <i class="bi bi-box-arrow-in-right me-2"></i>Go to Login
            </a>
          </div>
        <% } %>

        <% if (!success && token) { %>
          <form action="/auth/reset-password/<%= token %>"
                method="POST"
                class="needs-validation" novalidate>

            <div class="mb-3">
              <label for="new_password" class="form-label fw-semibold">
                New Password
              </label>
              <div class="input-group has-validation">
                <span class="input-group-text">
                  <i class="bi bi-key"></i>
                </span>
                <input type="password"
                       class="form-control"
                       id="new_password"
                       name="new_password"
                       placeholder="Min. 8 characters"
                       minlength="8"
                       pattern="^(?=.*[A-Za-z])(?=.*\d).{8,}$"
                       required />
                <div class="invalid-feedback">
                  Must be at least 8 characters with one letter and one number.
                </div>
              </div>
              <!-- Strength bar -->
              <div class="progress mt-2" style="height:4px;">
                <div id="passwordStrengthBar"
                     class="progress-bar"
                     style="width:0%;transition:width 0.3s;">
                </div>
              </div>
              <div class="form-text">
                <span id="passwordStrengthText"></span>
              </div>
            </div>

            <div class="mb-4">
              <label for="confirm_password" class="form-label fw-semibold">
                Confirm Password
              </label>
              <div class="input-group has-validation">
                <span class="input-group-text">
                  <i class="bi bi-key-fill"></i>
                </span>
                <input type="password"
                       class="form-control"
                       id="confirm_password"
                       name="confirm_password"
                       placeholder="Repeat new password"
                       required />
                <div class="invalid-feedback">
                  Passwords do not match.
                </div>
              </div>
            </div>

            <div class="d-grid">
              <button type="submit" class="btn btn-primary btn-lg">
                <i class="bi bi-check-circle me-2"></i>Reset Password
              </button>
            </div>

          </form>
        <% } %>

        <% if (!success && !token) { %>
          <div class="d-grid mt-2">
            <a href="/auth/forgot-password"
               class="btn btn-outline-primary">
              Request a New Reset Link
            </a>
          </div>
        <% } %>

      </div>
    </div>

    <p class="text-center text-muted small mt-3">
      <a href="/auth/login" class="text-decoration-none">
        <i class="bi bi-arrow-left me-1"></i>Back to Login
      </a>
    </p>

  </div>
</div>

<%- include('../layouts/footer') %>